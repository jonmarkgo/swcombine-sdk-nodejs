          },
          {
            "group": "Guides",
            "pages": [
              "guides/typescript-usage",
              "guides/timestamp-utility",
              "guides/migration-v3"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "Full coverage of 60+ SW Combine API v2.0 endpoints across 11 resource categories",
    "Built-in OAuth 2.0 authentication with automatic token refresh",
    "Page<T> pagination with async iterator support for auto-pagination",
    "170+ type-safe OAuth scope constants with TypeScript autocomplete",
    "Automatic retry with exponential backoff for failed requests",
    "Dual ESM and CommonJS module support for Node.js 18+",
    "Zero production dependencies (except axios)",
    "Combine Galactic Time (CGT) Timestamp utility"
  ],
  "publicApiSurface": [
    "SWCombine (main client class)",
    "client.character.me()",
    "client.character.get({ uid })",
    "client.character.getByHandle({ handle })",
    "client.character.messages.list(options)",
    "client.character.messages.get(options)",
