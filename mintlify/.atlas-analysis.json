{
  "projectType": "sdk-library",
  "projectName": "SW Combine SDK",
  "projectDescription": "A comprehensive TypeScript SDK for the Star Wars Combine API v2.0, providing OAuth 2.0 authentication, type-safe access to 60+ API endpoints, and automatic pagination.",
  "theme": "luma",
  "primaryColor": "#1a56db",
  "lightColor": "#e8f0fe",
  "darkColor": "#0f2d6b",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "authentication/overview",
              "authentication/oauth-flow",
              "authentication/scopes",
              "authentication/token-management"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/client-modes",
              "concepts/pagination",
              "concepts/error-handling",
              "concepts/rate-limits"
            ]
          },
          {
            "group": "API Resources",
            "pages": [
              "resources/character",
              "resources/faction",
              "resources/galaxy",
              "resources/inventory",
              "resources/market",
              "resources/news",
              "resources/events",
              "resources/types",
